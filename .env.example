# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# ── Storage ────────────────────────────────────────────────────────────────────
# Leave defaults to use project-derived bucket names, or override:
# UPLOAD_BUCKET=bb-uploads-your-project-id
# ASSETS_BUCKET=bb-assets-your-project-id
USE_GCS=false                         # true = GCS, false = local disk (local dev)
LOCAL_ASSETS_DIR=generated_assets

# ── Models ─────────────────────────────────────────────────────────────────────
# Image generation (Vertex AI global endpoint required for preview models)
IMAGE_MODEL=gemini-3.1-flash-image-preview
IMAGE_MODEL_FALLBACK=gemini-2.5-flash-image
IMAGE_MODEL_FALLBACK_2=gemini-2.0-flash-preview-image-generation

# Live API (voice conversation)
LIVE_API_MODEL=gemini-live-2.5-flash-native-audio
LIVE_API_VOICE=Charon
NARRATOR_VOICE=Kore

# ── Developer API fallback ─────────────────────────────────────────────────────
# Used when Vertex AI image generation fails or for local dev without ADC.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
USE_DEVELOPER_API_FALLBACK=true
DEVELOPER_API_IMAGE_MODEL=gemini-2.5-flash-image

# Set to true to skip Vertex AI entirely and use only GEMINI_API_KEY (local dev without ADC)
DEBUG_API_KEY_ONLY=false

# ── Auth ───────────────────────────────────────────────────────────────────────
# Bearer token for /ws and /upload endpoints. Leave empty to disable (local dev).
ACCESS_TOKEN=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_SEC=900
SESSION_WARNING_SEC=240
