        <mxCell id="session" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=11;verticalAlign=top;align=center;strokeWidth=2;" value="&lt;b style=&quot;font-size:12px&quot;&gt;Session + BrandCanvas&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px&quot;&gt;[In-Memory Store per session_id · 15-min TTL]&lt;/i&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;BrandCanvas (source of truth):&lt;/b&gt;&lt;br&gt;strategy: name · tagline · story · values · tone&lt;br&gt;design: palette · fonts&lt;br&gt;assets: logo · hero · instagram&lt;br&gt;audio: voiceover&lt;br&gt;&lt;br&gt;&lt;b&gt;ElementStatus:&lt;/b&gt; EMPTY | GENERATING | READY | STALE&lt;br&gt;No phase state machine — agent fully autonomous" vertex="1">
          <mxGeometry height="195" width="310" x="710" y="345" as="geometry" />
        </mxCell>
        <mxCell id="storage" parent="1" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=11;verticalAlign=top;align=center;strokeWidth=2;" value="&lt;b style=&#39;font-size:12px&#39;&gt;Asset Storage&lt;/b&gt;&lt;br/&gt;&lt;i style=&#39;font-size:10px&#39;&gt;[Local FS dev / GCS prod]&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Dev (USE_GCS=false):&lt;/b&gt;&lt;br/&gt;generated_assets/{session_id}/&lt;br/&gt;Served at /api/assets/*&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Prod (USE_GCS=true):&lt;/b&gt;&lt;br/&gt;GCS bb-uploads-{project} (input)&lt;br/&gt;GCS bb-assets-{project} (output)&lt;br/&gt;Signed URLs · v4 · 1h TTL" vertex="1">
