        <mxCell id="api" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;fontSize=11;verticalAlign=top;align=center;strokeWidth=2;" value="&lt;b style=&#39;font-size:13px&#39;&gt;FastAPI Backend&lt;/b&gt;&lt;br/&gt;&lt;i style=&#39;font-size:10px&#39;&gt;[Container: API Application · Python 3.11 + uvicorn]&lt;/i&gt;&lt;br/&gt;&lt;br/&gt;WS  /ws/{session_id}  — Live API bridge&lt;br/&gt;POST /api/upload — product image&lt;br/&gt;GET  /api/download/{session_id} — ZIP&lt;br/&gt;GET  /api/health&lt;br/&gt;GET  /* — SPA static files&lt;br/&gt;&lt;br/&gt;&lt;b&gt;4 async tasks per session:&lt;/b&gt;&lt;br/&gt;agent_loop · receive_loop · keepalive · watchdog" vertex="1">
          <mxGeometry height="215" width="310" x="710" y="90" as="geometry" />
